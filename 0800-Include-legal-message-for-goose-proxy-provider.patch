index 000000000..4f63937c8
--- /dev/null
+++ b/crates/goose-cli/src/legal.rs
@@ -0,0 +1,32 @@
+use console::style;
+use goose::config::Config;
+
+/// Checks whether the configured provider is the Red Hat proxy.
+fn is_provider_rhel() -> bool {
+    let rhel_provider: &str = "rhel_cla";
+    Config::global()
+        .get_goose_provider()
+        .ok()
+        .map(|p| p.to_lowercase().contains(rhel_provider))
+        .unwrap_or(false)
+}
+
+/// Displays the initial legal disclaimer about AI usage and data handling.
+pub fn display_disclaimer() {
+    let disclaimer = "⚠️ This tool uses AI technology. Do not include any personal information or \
+        other sensitive information in your input. Interactions may be used to \
+        improve Red Hat's products or services.\n";
+    let colored_disclaimer = style(disclaimer).yellow();
+    if is_provider_rhel() {
+        println!("{}", colored_disclaimer);
+    }
+}
+
+/// Displays a short reminder to review AI-generated content.
+pub fn display_always_disclaimer() {
+    let disclaimer = "Always review AI-generated content prior to use.";
+    let colored_disclaimer = style(disclaimer).yellow().dim();
+    if is_provider_rhel() {
+        println!("{}", colored_disclaimer);
+    }
+}
